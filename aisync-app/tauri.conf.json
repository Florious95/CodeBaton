{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeBaton",
  "version": "0.1.0",
  "identifier": "com.aisync.app",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "theme": "Dark",
        "visible": true,
        "focus": true,
        "center": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
